---
import type { FAQ } from '../data/servicios';

interface Props {
  faqs: FAQ[];
}
const { faqs } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.pregunta,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.respuesta,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
