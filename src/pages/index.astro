---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ciudades, EMPRESA } from '../data/index';
import { siteConfig } from '../config/site';

const title       = `Vaciado de pisos y locales en Terrassa – Presupuesto gratis | ${siteConfig.businessName}`;
const description = `Servicio de vaciado de pisos, locales y recogida de muebles en Terrassa y comarca. Presupuesto gratuito en 24 h, equipo propio, gestión de residuos certificada. Llama al ${siteConfig.phone}.`;

const terrassa = ciudades.find(c => c.slug === 'terrassa') ?? ciudades[0];

const faqs = [
  {
    pregunta: '¿Cuánto cuesta vaciar un piso en Terrassa?',
    respuesta: 'El precio depende del tamaño y el volumen de enseres. Un piso de 70–90 m² suele estar entre 250 € y 500 €. Te enviamos presupuesto gratuito en menos de 24 horas, sin visita previa en muchos casos (basta con fotos).',
  },
  {
    pregunta: '¿Cuánto tiempo tarda el vaciado?',
    respuesta: 'La mayoría de pisos se vacían en un solo día. Un piso de 3 habitaciones con mobiliario completo lleva entre 4 y 8 horas con nuestro equipo. Los locales comerciales dependen del volumen.',
  },
  {
    pregunta: '¿Qué hacéis con los muebles y objetos retirados?',
    respuesta: 'Separamos los objetos en buen estado para donarlos a entidades sociales o canales de segunda mano. El resto se lleva a puntos de reciclaje autorizados en la provincia de Barcelona. Trabajamos de forma responsable.',
  },
  {
    pregunta: '¿Podéis vaciar un piso de herencia con trámites pendientes?',
    respuesta: 'Sí. Trabajamos habitualmente con gestorías, notarías y familiares en proceso de herencia. Podemos coordinar el vaciado con los tiempos legales y documentar lo retirado si es necesario.',
  },
  {
    pregunta: '¿Trabajáis en fines de semana?',
    respuesta: 'Sí, disponemos de servicio en fines de semana con cita previa. Consulta disponibilidad al solicitar el presupuesto.',
  },
  {
    pregunta: '¿El presupuesto es realmente gratuito?',
    respuesta: 'Sí, 100% gratuito y sin compromiso. En muchos casos te lo damos por teléfono o WhatsApp con fotos. Si el trabajo lo requiere, hacemos visita previa también sin coste.',
  },
];
---

<BaseLayout title={title} description={description}>

  <!-- ① HERO LOCAL ─────────────────────────────────────── -->
  <section class="hero" aria-label="Presentación del servicio">
    <div class="container hero-inner">

      <div class="hero-text">
        <span class="eyebrow hero-eyebrow">Servicio local en Terrassa y comarca</span>

        <h1>
          Vaciado de pisos y locales<br />
          <span class="hero-h1-accent">en Terrassa</span>
        </h1>

        <p class="hero-sub">
          Retiramos muebles, trastos y residuos de cualquier inmueble.
          Presupuesto gratuito en 24&nbsp;h, equipo propio y gestión de residuos certificada.
        </p>

        <div class="hero-ctas">
          <a href={`tel:${terrassa.telefono.replace(/\s/g,'')}`} class="btn btn-primary btn-lg">
            📞 Llamar ahora — {terrassa.telefono}
          </a>
          <a href="#contacto-form" class="btn btn-ghost btn-lg">
            Pedir presupuesto gratis
          </a>
        </div>

        <ul class="hero-badges" aria-label="Ventajas del servicio">
          <li><span aria-hidden="true">⚡</span> Presupuesto en menos de 24&nbsp;h</li>
          <li><span aria-hidden="true">🏠</span> Pisos, locales y naves</li>
          <li><span aria-hidden="true">♻️</span> Gestión de residuos certificada</li>
          <li><span aria-hidden="true">✅</span> Equipo propio, sin subcontratas</li>
        </ul>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="hero-card">
          <div class="hero-card-header">
            <span class="status-dot"></span>
            <span>Disponible ahora en Terrassa</span>
          </div>
          <p class="hero-card-stat">+500</p>
          <p class="hero-card-label">vaciados realizados</p>
          <div class="hero-card-metrics">
            <div><strong>{ciudades.length}</strong><span>municipios</span></div>
            <div><strong>24 h</strong><span>presupuesto</span></div>
            <div><strong>4,9 ★</strong><span>valoración</span></div>
          </div>
          <hr class="hero-card-divider" />
          <p class="hero-card-caption">Zona de actuación</p>
          <div class="hero-card-cities">
            {ciudades.map(c => <span>{c.nombre}</span>)}
          </div>
        </div>
      </div>

    </div>

    <div class="hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#f8fafc"/>
      </svg>
    </div>
  </section>

  <!-- ② BENEFICIOS / POR QUÉ ELEGIRNOS ────────────────── -->
  <section class="sec sec--tint" aria-labelledby="beneficios-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="beneficios-heading">¿Por qué elegirnos para vaciar tu piso en Terrassa?</h2>
        <p class="section-sub">Más de 10 años vaciando inmuebles en el Vallès Occidental. Equipo propio, sin subcontratas y con gestión de residuos certificada.</p>
      </div>

      <ul class="benefits-grid" role="list">
        <li class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>Equipo propio en Terrassa</h3>
          <p>No subcontratamos. Nuestros operarios son empleados directos con formación y seguro. Trato directo y responsable siempre.</p>
        </li>
        <li class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3>Presupuesto en menos de 24 h</h3>
          <p>Envíanos fotos por WhatsApp y te respondemos con precio cerrado sin visita previa. Sin esperas ni desplazamientos innecesarios.</p>
        </li>
        <li class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
            </svg>
          </div>
          <h3>Precio cerrado, sin sorpresas</h3>
          <p>El presupuesto que aceptas es el precio final. No hay extras ocultos ni costes adicionales al terminar el trabajo.</p>
        </li>
        <li class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
            </svg>
          </div>
          <h3>Gestión de residuos certificada</h3>
          <p>Llevamos todo a gestores autorizados en la provincia de Barcelona. Podemos emitir certificado de gestión si lo necesitas para baja de actividad o herencia.</p>
        </li>
        <li class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
            </svg>
          </div>
          <h3>Donamos a entidades sociales</h3>
          <p>Los muebles y objetos en buen estado los donamos a asociaciones locales de Terrassa y el Vallès. Damos una segunda vida a todo lo que sea reutilizable.</p>
        </li>
        <li class="benefit-card">
          <div class="benefit-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
            </svg>
          </div>
          <h3>Discreción total en casos sensibles</h3>
          <p>Herencias, síndrome de Diógenes, desahucios o separaciones. Actuamos con máximo respeto y confidencialidad en situaciones delicadas.</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- ③ SERVICIOS DETALLADOS ──────────────────────────── -->
  <section class="sec" aria-labelledby="servicios-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="servicios-heading">Nuestros servicios de vaciado en Terrassa</h2>
        <p class="section-sub">Vaciado integral, limpieza especializada y pintura express. Todo lo que necesitas para dejar el inmueble listo.</p>
      </div>

      <p class="srv-grid-intro">
        Servicios de <a href="/servicios/">vaciado y limpieza en Terrassa</a>. Equipo propio, presupuesto gratuito y gestión de residuos certificada.
      </p>

      <ul class="srv-grid" role="list">
        <li class="srv-card srv-card--featured">
          <div class="srv-card-badge">Más solicitado</div>
          <div class="srv-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <h3>Vaciado de pisos</h3>
          <p>Retiramos muebles, electrodomésticos, ropa y enseres. El piso queda vacío y limpio en un solo día. Ideal para herencias, reformas o cambio de inquilino.</p>
          <ul class="srv-features">
            <li>✓ Muebles, electrodomésticos y ropa</li>
            <li>✓ Vaciado completo en un día</li>
            <li>✓ Limpieza básica incluida</li>
          </ul>
          <a href="/terrassa/vaciado-pisos/" class="btn btn-primary">Ver servicio →</a>
        </li>

        <li class="srv-card">
          <div class="srv-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
            </svg>
          </div>
          <h3>Vaciado de locales comerciales</h3>
          <p>Oficinas, tiendas, almacenes y naves. Desmontamos estanterías y mobiliario fijo. Gestión de residuos con certificado incluido.</p>
          <ul class="srv-features">
            <li>✓ Desmontaje de estanterías</li>
            <li>✓ Certificado de residuos</li>
            <li>✓ Horario flexible</li>
          </ul>
          <a href="/terrassa/vaciado-locales/" class="btn btn-primary">Ver servicio →</a>
        </li>

        <li class="srv-card">
          <div class="srv-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6M10 11v6M14 11v6M9 6V4h6v2"/>
            </svg>
          </div>
          <h3>Recogida de muebles sueltos</h3>
          <p>Sofá, armario, cama, electrodomésticos… Subimos a buscarlos y te quitamos el problema. Sin necesidad de vaciar el piso entero.</p>
          <ul class="srv-features">
            <li>✓ Subimos hasta tu piso</li>
            <li>✓ Precio por volumen</li>
            <li>✓ Mismo día en muchos casos</li>
          </ul>
          <a href="/terrassa/recogida-muebles/" class="btn btn-primary">Ver servicio →</a>
        </li>

        <li class="srv-card">
          <div class="srv-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>Limpieza síndrome de Diógenes</h3>
          <p>Actuación discreta en viviendas con acumulación severa. Desinfección, retirada de residuos orgánicos y recuperación completa del inmueble.</p>
          <ul class="srv-features">
            <li>✓ Total confidencialidad</li>
            <li>✓ Desinfección profunda</li>
            <li>✓ Equipo especializado</li>
          </ul>
          <a href="/contacto" class="btn btn-primary">Solicitar presupuesto →</a>
        </li>

        <li class="srv-card">
          <div class="srv-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <h3>Limpieza post vaciado</h3>
          <p>Tras el vaciado, limpieza profunda de suelos, paredes, cocina y baños. El inmueble queda listo para visita, venta o alquiler inmediato.</p>
          <ul class="srv-features">
            <li>✓ Limpieza de suelos y paredes</li>
            <li>✓ Cocina y baños a fondo</li>
            <li>✓ Combinable con vaciado</li>
          </ul>
          <a href="/contacto" class="btn btn-primary">Solicitar presupuesto →</a>
        </li>

        <li class="srv-card">
          <div class="srv-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 17l4-8 4 5 3-3 4 6"/><circle cx="12" cy="5" r="2"/>
            </svg>
          </div>
          <h3>Pintura express</h3>
          <p>Pintamos pisos y locales recién vaciados en 24–48 h con acabado profesional. Ideal para rentabilizar el inmueble lo antes posible.</p>
          <ul class="srv-features">
            <li>✓ Acabado en 24–48 h</li>
            <li>✓ Combinable con vaciado</li>
            <li>✓ Precio cerrado</li>
          </ul>
          <a href="/contacto" class="btn btn-primary">Solicitar presupuesto →</a>
        </li>
      </ul>
    </div>
  </section>

  <!-- ④ ZONA DE ACTUACIÓN ──────────────────────────────── -->
  <section class="sec sec--tint" aria-labelledby="zona-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="zona-heading">Zona de actuación: Terrassa y alrededores</h2>
        <p class="section-sub">Cubrimos Terrassa y {ciudades.length - 1} municipios del Vallès Occidental. Desplazamiento incluido en el presupuesto.</p>
      </div>

      <ul class="zona-grid" role="list">
        {ciudades.map(ciudad => (
          <li class="zona-card">
            <div class="zona-card-header">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <path d="M8 1.5C5.52 1.5 3.5 3.52 3.5 6c0 3.75 4.5 8.5 4.5 8.5s4.5-4.75 4.5-8.5c0-2.48-2.02-4.5-4.5-4.5z"/><circle cx="8" cy="6" r="1.5"/>
              </svg>
              <strong>{ciudad.nombre}</strong>
            </div>
            <ul class="zona-services">
              {ciudad.servicios.map(s => (
                <li>
                  <a href={`/${ciudad.slug}/${s.slug}/`}>{s.nombre} en {ciudad.nombre}</a>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>

      <div class="zona-barrios">
        <p class="zona-barrios-label">También en los barrios de Terrassa:</p>
        <ul class="zona-tags" role="list">
          {terrassa.zonas.map(z => <li>{z}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- ⑤ PROCESO DE TRABAJO ─────────────────────────────── -->
  <section class="sec" aria-labelledby="proceso-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="proceso-heading">Cómo trabajamos: 4 pasos sin complicaciones</h2>
        <p class="section-sub">Un proceso claro y transparente desde el primer contacto hasta la entrega del inmueble vacío.</p>
      </div>

      <ol class="proceso-steps">
        <li>
          <div class="proceso-num" aria-hidden="true">1</div>
          <div class="proceso-content">
            <h3>Contacto y presupuesto gratuito</h3>
            <p>Llámanos, escríbenos por WhatsApp o rellena el formulario. Envíanos fotos del inmueble y en menos de <strong>24 horas</strong> recibes un presupuesto cerrado y sin letra pequeña.</p>
          </div>
        </li>
        <li>
          <div class="proceso-num" aria-hidden="true">2</div>
          <div class="proceso-content">
            <h3>Confirmación y fecha</h3>
            <p>Aceptas el presupuesto y fijamos el día. Nos adaptamos a tu disponibilidad, incluidos <strong>fines de semana</strong> si es necesario. No pedimos señal.</p>
          </div>
        </li>
        <li>
          <div class="proceso-num" aria-hidden="true">3</div>
          <div class="proceso-content">
            <h3>Vaciado completo</h3>
            <p>Nuestro equipo acude puntual, protege escaleras y zonas comunes, y vacía el inmueble de forma ordenada y eficiente. En la mayoría de casos <strong>terminamos en el mismo día</strong>.</p>
          </div>
        </li>
        <li>
          <div class="proceso-num" aria-hidden="true">4</div>
          <div class="proceso-content">
            <h3>Entrega y gestión de residuos</h3>
            <p>Dejamos el inmueble vacío y con limpieza básica. Los residuos se llevan a gestores autorizados. Si lo necesitas, emitimos <strong>certificado de gestión</strong>.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ⑥ TESTIMONIOS ────────────────────────────────────── -->
  <section class="sec sec--dark" aria-labelledby="testimonios-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="testimonios-heading">Lo que dicen nuestros clientes en Terrassa</h2>
        <p class="section-sub-dark">Más de 500 familias y empresas han confiado en nosotros en el Vallès Occidental.</p>
      </div>

      <div class="testimonios-track" role="list">
        <article class="testimonio-card" role="listitem">
          <div class="testimonio-stars" aria-label="5 estrellas">★★★★★</div>
          <blockquote>
            <p>"Vaciaron el piso de mi madre en un solo día. Puntuales, limpios y muy amables. Se llevaron todo sin dejar rastro y donaron los muebles en buen estado. 100% recomendables."</p>
          </blockquote>
          <footer>
            <div class="testimonio-avatar">MC</div>
            <div>
              <cite class="testimonio-nombre">Marta C.</cite>
              <span class="testimonio-lugar">Terrassa · Vaciado de piso</span>
            </div>
          </footer>
        </article>

        <article class="testimonio-card" role="listitem">
          <div class="testimonio-stars" aria-label="5 estrellas">★★★★★</div>
          <blockquote>
            <p>"Necesitaba vaciar un local antes de entregar las llaves. Me dieron presupuesto el mismo día y lo tuvieron listo en 48 horas. Precio justo y sin sorpresas."</p>
          </blockquote>
          <footer>
            <div class="testimonio-avatar">JR</div>
            <div>
              <cite class="testimonio-nombre">Jordi R.</cite>
              <span class="testimonio-lugar">Sabadell · Vaciado de local</span>
            </div>
          </footer>
        </article>

        <article class="testimonio-card" role="listitem">
          <div class="testimonio-stars" aria-label="5 estrellas">★★★★★</div>
          <blockquote>
            <p>"Recogieron un sofá, dos armarios y varios electrodomésticos. Subieron hasta el tercero sin ascensor sin ningún problema. Rápido, económico y muy profesional."</p>
          </blockquote>
          <footer>
            <div class="testimonio-avatar">AL</div>
            <div>
              <cite class="testimonio-nombre">Anna L.</cite>
              <span class="testimonio-lugar">Rubí · Recogida de muebles</span>
            </div>
          </footer>
        </article>

        <article class="testimonio-card" role="listitem">
          <div class="testimonio-stars" aria-label="5 estrellas">★★★★★</div>
          <blockquote>
            <p>"Tras el fallecimiento de mi padre tuve que gestionar el vaciado de su piso. El equipo fue muy respetuoso y eficiente. Me quitaron un gran peso en un momento difícil."</p>
          </blockquote>
          <footer>
            <div class="testimonio-avatar">PG</div>
            <div>
              <cite class="testimonio-nombre">Pere G.</cite>
              <span class="testimonio-lugar">Sant Quirze · Vaciado de piso</span>
            </div>
          </footer>
        </article>
      </div>

      <div class="testimonio-hint" aria-hidden="true">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 8l6 6 6-6"/></svg>
        Desliza para ver más
      </div>
    </div>
  </section>

  <!-- ⑦ PRECIOS ORIENTATIVOS ───────────────────────────── -->
  <section class="sec sec--tint" aria-labelledby="precios-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="precios-heading">Precios orientativos del vaciado en Terrassa</h2>
        <p class="section-sub">Presupuesto final gratuito y sin compromiso. Estos precios son orientativos — el coste real depende del volumen y accesibilidad.</p>
      </div>

      <ul class="precios-grid" role="list">
        <li class="precio-card">
          <div class="precio-tipo">Habitación o estudio</div>
          <div class="precio-desde">desde</div>
          <div class="precio-valor">150 €</div>
          <ul class="precio-incl">
            <li>Hasta 20 m²</li>
            <li>Muebles y enseres básicos</li>
            <li>1–2 operarios, ½ día</li>
            <li>Gestión de residuos</li>
          </ul>
          <a href={`tel:${terrassa.telefono.replace(/\s/g,'')}`} class="btn btn-primary btn-full">Pedir precio exacto</a>
