---
/**
 * Layout compartido para todas las páginas.
 * Incluye: HTML shell, Inter font, header fijo con nav por rutas,
 * footer y todos los estilos globales (tokens, reset, botones, etc.).
 */
import SEOHead from '../components/SEOHead.astro';
import { EMPRESA } from '../data/empresa';
// siteConfig es la fuente de verdad. Edita src/config/site.ts para
// personalizar businessName, serviceType, area, phone, etc.
import { siteConfig } from '../config/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical = siteConfig.web + Astro.url.pathname } = Astro.props;

// Resalta el enlace activo comparando con la ruta actual
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

const navLinks = [
  { href: '/',              label: 'Inicio' },
  { href: '/sobre-nosotros', label: 'Quiénes somos' },
  { href: '/servicios',      label: 'Servicios' },
  { href: '/faq',            label: 'FAQ' },
  { href: '/contacto',       label: 'Contacto' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <SEOHead title={title} description={description} canonical={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Carga de fuente non-blocking: no bloquea el render -->
    <link rel="preload" as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    </noscript>
    <slot name="head" />
  </head>

  <body>

    <!-- ── Header fijo ──────────────────────────────────── -->
    <header class="site-header">
      <div class="container header-inner">

        <a href="/" class="brand" aria-label="Ir al inicio">
          <span class="brand-icon" aria-hidden="true">◈</span>
          <span class="brand-name">{EMPRESA.nombre}</span>
        </a>

        <nav class="main-nav" aria-label="Navegación principal">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          ))}
        </nav>

        <a href="/contacto" class="btn btn-sm">Solicitar presupuesto</a>

        <button
          class="nav-toggle"
          aria-label="Abrir menú"
          aria-expanded="false"
          onclick="this.setAttribute('aria-expanded',
            this.getAttribute('aria-expanded')==='false' ? 'true' : 'false');
            document.querySelector('.main-nav').classList.toggle('open')"
        >
          <span></span><span></span><span></span>
        </button>

      </div>
    </header>

    <!-- ── Contenido de la página ────────────────────────── -->
    <main>
      <slot />
    </main>

    <!-- ── Footer ────────────────────────────────────────── -->
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <span class="brand-icon" aria-hidden="true">◈</span>
          <span class="brand-name">{EMPRESA.nombre}</span>
        </div>

        <nav class="footer-nav" aria-label="Navegación footer">
          {navLinks.map(({ href, label }) => (
            <a href={href}>{label}</a>
          ))}
        </nav>

        <p class="footer-legal">
          &copy; {new Date().getFullYear()} {EMPRESA.nombreLegal}
          &nbsp;·&nbsp;<a href="/privacidad/">Privacidad</a>
          &nbsp;·&nbsp;<a href="/aviso-legal/">Aviso legal</a>
        </p>
      </div>
    </footer>

    <!-- ── Volver arriba ────────────────────────────── -->
    <button id="back-to-top" class="back-to-top" aria-label="Volver arriba" hidden>
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 15V5M5 10l5-5 5 5"/>
      </svg>
    </button>

    <script is:inline defer>
      (function () {
        const btn = document.getElementById('back-to-top');
        if (!btn) return;
        window.addEventListener('scroll', function () {
          btn.hidden = window.scrollY < 400;
        }, { passive: true });
        btn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>

    <!-- ── Cookie banner ─────────────────────────────── -->
    <div id="cookie-banner" class="cookie-banner" role="dialog" aria-live="polite"
         aria-label="Aviso de cookies" hidden>
      <div class="cookie-inner">
        <p class="cookie-text">
          Usamos cookies técnicas necesarias para el funcionamiento del sitio.
          No utilizamos cookies de seguimiento ni publicidad.
          <a href="/privacidad/">Más información</a>.
        </p>
        <div class="cookie-actions">
          <button id="cookie-accept" class="cookie-btn cookie-btn--accept">
            Aceptar
          </button>
          <button id="cookie-reject" class="cookie-btn cookie-btn--reject">
            Rechazar
          </button>
        </div>
      </div>
    </div>

    <script is:inline defer>
      (function () {
        const KEY = 'cookie_consent';
        const banner = document.getElementById('cookie-banner');
        if (!banner) return;
        // Mostrar solo si el usuario no ha decidido aún
        if (!localStorage.getItem(KEY)) {
          banner.hidden = false;
        }
        document.getElementById('cookie-accept')?.addEventListener('click', function () {
          localStorage.setItem(KEY, 'accepted');
          banner.hidden = true;
        });
        document.getElementById('cookie-reject')?.addEventListener('click', function () {
          localStorage.setItem(KEY, 'rejected');
          banner.hidden = true;
        });
      })();
    </script>

  </body>
</html>

<style is:global>
  /* ══════════════════════════════════════════════════════════
     DESIGN TOKENS
  ══════════════════════════════════════════════════════════ */
  :root {
    --c-bg:        #ffffff;
    --c-bg-tint:   #f8fafc;
    --c-bg-dark:   #0f172a;
    --c-primary:   #0057ff;
    --c-primary-d: #0041cc;
    --c-primary-l: #eff6ff;
    --c-text:      #0f172a;
    --c-text-m:    #475569;
    --c-text-l:    #94a3b8;
    --c-border:    #e2e8f0;
    --c-white:     #ffffff;
    --c-green:     #22c55e;
    --c-whatsapp:  #25d366;

    --r-sm: 8px;
    --r-md: 12px;
    --r-lg: 18px;
    --r-xl: 24px;

    --sh-card: 0 1px 3px rgba(0,0,0,.07), 0 4px 16px rgba(0,0,0,.06);

    --font:     'Inter', system-ui, -apple-system, sans-serif;
    --max-w:    1140px;
    --header-h: 64px;
  }

  /* ══════════════════════════════════════════════════════════
     RESET + BASE
  ══════════════════════════════════════════════════════════ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: var(--header-h);
    font-size: 16px;
  }

  body {
    font-family: var(--font);
    color: var(--c-text);
    background: var(--c-bg);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  img, svg { display: block; max-width: 100%; }
  a { color: var(--c-primary); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ══════════════════════════════════════════════════════════
     LAYOUT HELPERS
  ══════════════════════════════════════════════════════════ */
  .container {
    width: 100%;
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: 1.25rem;
  }

  /* Sección genérica con padding vertical */
  .page-section          { padding-block: 5rem; }
  .page-section--tinted  { background: var(--c-bg-tint); }
  .page-section--dark    { background: var(--c-bg-dark); }
  @media (max-width: 768px) { .page-section { padding-block: 3.5rem; } }

  /* Cabecera centrada de sección */
  .section-header {
    text-align: center;
    max-width: 720px;
    margin-inline: auto;
    margin-bottom: 3rem;
  }
  .section-sub {
    color: var(--c-text-m);
    font-size: 1rem;
    line-height: 1.7;
    margin-top: .75rem;
  }

  /* ══════════════════════════════════════════════════════════
     TYPOGRAPHY
  ══════════════════════════════════════════════════════════ */
  h1 { font-size: clamp(2rem, 5vw, 3rem);   font-weight: 800; line-height: 1.15; letter-spacing: -.02em; }
  h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 700; line-height: 1.25; letter-spacing: -.015em; margin-top: .5rem; }
  h3 { font-size: 1.05rem; font-weight: 600; }

  .eyebrow {
    display: inline-block;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--c-primary);
    background: var(--c-primary-l);
    padding: .25rem .75rem;
    border-radius: 100px;
    margin-bottom: .75rem;
  }
  .eyebrow--light {
    color: rgba(255,255,255,.8);
    background: rgba(255,255,255,.12);
  }

  /* ══════════════════════════════════════════════════════════
     BUTTONS
  ══════════════════════════════════════════════════════════ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-family: var(--font);
    font-weight: 600;
    font-size: .9rem;
    padding: .55rem 1.25rem;
    border-radius: var(--r-sm);
    border: 2px solid transparent;
    cursor: pointer;
    transition: all .18s ease;
    white-space: nowrap;
    text-decoration: none;
    line-height: 1;
  }
  .btn:hover { text-decoration: none; }

  .btn--primary  { background: var(--c-primary);   color: #fff; border-color: var(--c-primary); }
  .btn--primary:hover { background: var(--c-primary-d); border-color: var(--c-primary-d); }

  .btn--ghost    { background: transparent; color: #fff; border-color: rgba(255,255,255,.4); }
  .btn--ghost:hover { background: rgba(255,255,255,.1); border-color: rgba(255,255,255,.7); }

  .btn--outline  { background: transparent; color: var(--c-primary); border-color: var(--c-primary); }
  .btn--outline:hover { background: var(--c-primary-l); }

  .btn--white    { background: #fff; color: var(--c-primary); border-color: #fff; }
  .btn--white:hover { background: #f0f4ff; }

  .btn--whatsapp { background: var(--c-whatsapp); color: #fff; border-color: var(--c-whatsapp); }
  .btn--whatsapp:hover { background: #1db550; }

  .btn--sm   { font-size: .8rem;  padding: .45rem 1rem; }
  .btn--lg   { font-size: 1rem;   padding: .8rem 1.75rem; }
  .btn--full { width: 100%; justify-content: center; }

  /* Aliases sin BEM para compatibilidad con código existente */
  .btn-primary  { background: var(--c-primary);   color: #fff; border-color: var(--c-primary); }
  .btn-primary:hover { background: var(--c-primary-d); }
  .btn-ghost    { background: transparent; color: #fff; border-color: rgba(255,255,255,.4); }
  .btn-ghost:hover   { background: rgba(255,255,255,.1); }
  .btn-white    { background: #fff; color: var(--c-primary); border-color: #fff; }
  .btn-white:hover   { background: #f0f4ff; }
  .btn-whatsapp { background: var(--c-whatsapp); color: #fff; border-color: var(--c-whatsapp); }
  .btn-whatsapp:hover { background: #1db550; }
  .btn-sm   { font-size: .8rem;  padding: .45rem 1rem; }
  .btn-lg   { font-size: 1rem;   padding: .8rem 1.75rem; }
  .btn-full { width: 100%; justify-content: center; }

  /* ══════════════════════════════════════════════════════════
     HEADER
  ══════════════════════════════════════════════════════════ */
  .site-header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 100;
    height: var(--header-h);
    background: rgba(255,255,255,.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--c-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 100%;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: .45rem;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--c-text);
    flex-shrink: 0;
    text-decoration: none;
  }
  .brand:hover { text-decoration: none; }
  .brand-icon  { color: var(--c-primary); font-size: 1.3rem; }

  .main-nav {
    display: flex;
    align-items: center;
    gap: .25rem;
    margin-inline-start: auto;
  }

  .main-nav a {
    font-size: .88rem;
    font-weight: 500;
    color: var(--c-text-m);
    padding: .4rem .75rem;
    border-radius: var(--r-sm);
    transition: all .15s;
    text-decoration: none;
  }
  .main-nav a:hover               { color: var(--c-primary); background: var(--c-primary-l); }
  .main-nav a[aria-current="page"] {
    color: var(--c-primary);
    background: var(--c-primary-l);
    font-weight: 600;
  }

  /* Hamburger */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: .5rem;
    margin-inline-start: auto;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--c-text);
    border-radius: 2px;
    transition: all .2s;
  }

  /* ══════════════════════════════════════════════════════════
     FOOTER
  ══════════════════════════════════════════════════════════ */
  .site-footer {
    background: #050d1a;
    padding-block: 2rem;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .footer-brand { display: flex; align-items: center; gap: .4rem; font-weight: 600; font-size: .9rem; }
  .footer-brand .brand-icon { color: var(--c-primary); }
  .footer-brand .brand-name { color: rgba(255,255,255,.7); }

  .footer-nav { display: flex; flex-wrap: wrap; gap: .25rem; }
  .footer-nav a {
    font-size: .8rem;
    color: rgba(255,255,255,.4);
    padding: .3rem .6rem;
    border-radius: 5px;
    transition: color .15s;
  }
  .footer-nav a:hover { color: rgba(255,255,255,.8); text-decoration: none; }

  .footer-legal { font-size: .78rem; color: rgba(255,255,255,.3); }
  .footer-legal a { color: rgba(255,255,255,.4); text-decoration: underline; }

  /* ══════════════════════════════════════════════════════════
     MOBILE — nav desplegable
  ══════════════════════════════════════════════════════════ */
  @media (max-width: 768px) {
    .site-header .btn-sm { display: none; }

    .main-nav {
      display: none;
      position: absolute;
      top: var(--header-h);
      inset-inline: 0;
      flex-direction: column;
      background: var(--c-white);
      border-bottom: 1px solid var(--c-border);
      padding: 1rem 1.25rem;
      gap: .25rem;
      box-shadow: 0 8px 24px rgba(0,0,0,.1);
    }
    .main-nav.open { display: flex; }
    .main-nav a { font-size: .95rem; padding: .65rem .9rem; }

    .nav-toggle { display: flex; }
  }

  /* ══════════════════════════════════════════════════════════
     BACK TO TOP
  ══════════════════════════════════════════════════════════ */
  .back-to-top {
    position: fixed;
    bottom: 1.5rem;
    left: 1.5rem;
    z-index: 998;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: var(--c-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(0,87,255,.35);
    transition: background .15s, transform .15s, box-shadow .15s;
  }
  .back-to-top:hover {
    background: var(--c-primary-d);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0,87,255,.45);
  }
  .back-to-top svg { width: 18px; height: 18px; }

  /* ══════════════════════════════════════════════════════════
     COOKIE BANNER
  ══════════════════════════════════════════════════════════ */
  .cookie-banner {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 999;
    background: #0f172a;
    border-top: 1px solid rgba(255,255,255,.1);
    box-shadow: 0 -4px 24px rgba(0,0,0,.35);
  }

  .cookie-inner {
    max-width: var(--max-w);
    margin-inline: auto;
    padding: 1rem 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    justify-content: space-between;
  }

  .cookie-text {
    font-size: .85rem;
    color: rgba(255,255,255,.7);
    line-height: 1.6;
    margin: 0;
    flex: 1;
    min-width: 220px;
  }
  .cookie-text a { color: #7ab8f5; text-decoration: underline; }

  .cookie-actions {
    display: flex;
    gap: .6rem;
    flex-shrink: 0;
  }

  .cookie-btn {
    font-family: var(--font);
    font-size: .85rem;
    font-weight: 600;
    padding: .55rem 1.25rem;
    border-radius: var(--r-sm);
    border: none;
    cursor: pointer;
    transition: filter .15s;
    white-space: nowrap;
  }
  .cookie-btn:hover { filter: brightness(1.12); }

  .cookie-btn--accept {
    background: var(--c-primary);
    color: #fff;
  }
  .cookie-btn--reject {
    background: rgba(255,255,255,.1);
    color: rgba(255,255,255,.7);
    border: 1px solid rgba(255,255,255,.15);
  }
</style>
